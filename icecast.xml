<icecast>
    <location>Moscow</location>
    <admin>admin@solomoon.club</admin>

    <limits>
        <clients>200</clients>
        <sources>4</sources>
        <queue-size>65536</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <!-- low-latency: режем burst, новые слушатели стартуют почти моментально -->
        <burst-on-connect>0</burst-on-connect>
        <burst-size>0</burst-size>
    </limits>

    <authentication>
        <source-password>SOURCE_PASS_PLACEHOLDER</source-password>
        <relay-password>RELAY_PASS_PLACEHOLDER</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>ADMIN_PASS_PLACEHOLDER</admin-password>
    </authentication>

    <hostname>95.165.172.153</hostname>

    <listen-socket>
        <port>8000</port>
    </listen-socket>

    <http-headers>
        <header name="Access-Control-Allow-Origin" value="*" />
    </http-headers>

    <mount type="normal">
        <mount-name>/stream.mp3</mount-name>
        <max-listeners>200</max-listeners>
        <stream-name>SoloMoon's Club</stream-name>
        <stream-description>House · Deep House · EDM · R&amp;B — ночной коктейльный клуб Доброграда</stream-description>
        <stream-url>http://95.165.172.153:8000/</stream-url>
        <genre>House Deep-House EDM R&amp;B</genre>
        <bitrate>320</bitrate>
        <type>audio/mpeg</type>
        <public>0</public>
        <!-- fallback-mount не задан: нет резервного маунта, переключаться некуда.
             fallback-override=1 без fallback-mount разрывает соединения клиентов
             вместо того чтобы держать их — поэтому оба тега убраны. -->
        <fallback-override>0</fallback-override>
    </mount>

    <fileserve>1</fileserve>
    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>/var/log/icecast2</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
        <pidfile>/var/run/icecast2/icecast2.pid</pidfile>
        <alias source="/" destination="/status.xsl"/>
    </paths>

    <logging>
        <accesslog>access.log</accesslog>
        <errorlog>error.log</errorlog>
        <loglevel>3</loglevel>
        <logsize>10000</logsize>
    </logging>

    <security>
        <chroot>0</chroot>
    </security>
</icecast>
