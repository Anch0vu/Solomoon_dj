# Скопируй в .env и поменяй ВСЕ значения!

# ── Icecast ────────────────────────────────────────────────────────────────────
ICECAST_SOURCE_PASSWORD=CHANGE_ME_source_2024
ICECAST_ADMIN_PASSWORD=CHANGE_ME_admin_2024
ICECAST_RELAY_PASSWORD=CHANGE_ME_relay_2024
# Оставь пустым для публичного (без пароля) прослушивания:
# ICECAST_LISTENER_PASSWORD=

# ── Live DJ (Phase 3) ──────────────────────────────────────────────────────────
# Пароль, которым ffmpeg аутентифицируется на Liquidsoap harbor.
# Должен совпадать в обоих контейнерах (liquidsoap + radio-api).
HARBOR_PASSWORD=CHANGE_ME_harbor_2024

# Токен, который DJ вводит в браузерной деке (ws://host:8080/dj?token=...).
# Генерируй случайно: openssl rand -hex 32
DJ_TOKEN=CHANGE_ME_dj_token_2024

# ── Deployment ─────────────────────────────────────────────────────────────────
# Публичный IP или доменное имя сервера
SERVER_HOST=your.server.com
SERVER_PORT=8000

# Telegram notifications (optional)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
